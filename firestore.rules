rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable core safety getters
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Profiles collection rules (isolated write authority to owner)
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Card comments safety guidelines
    match /CardComment/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.author_name != null;
      allow update, delete: if isSignedIn();
    }

    // Proximity sessions dynamic networking synchronization
    match /ProximitySession/{sessionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // Digital business card metadata nodes
    match /BusinessCard/{cardId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}
